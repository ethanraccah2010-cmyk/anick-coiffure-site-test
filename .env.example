# =========================================================================
# ANICK COIFFURE — variables d'environnement (réservation Google Agenda)
# -------------------------------------------------------------------------
# Copiez ce fichier en ".env" pour un test local, et reportez les MÊMES
# valeurs dans Vercel : Settings > Environment Variables (Production ET
# Preview), puis Redeploy.
# NE COMMITEZ JAMAIS le fichier ".env" réel (il est ignoré par .gitignore).
# =========================================================================

# Identifiants OAuth (Google Cloud Console > Credentials > OAuth client ID)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Refresh token obtenu via OAuth Playground (scope Google Calendar)
GOOGLE_REFRESH_TOKEN=

# Agenda cible : "primary" pour l'agenda principal du compte, ou l'ID d'un
# agenda dédié (Agenda Google > Paramètres de l'agenda > Intégrer > ID).
GOOGLE_CALENDAR_ID=primary
